		"@types/jsdom": "^27.0.0",
		"@types/node": "^26.1.1",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@types/rss": "^0.0.32",
		"@vahor/llms-txt": "^0.2.0",
		"@vahor/rehype-d2": "0.0.9",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"rss": "^1.2.2",
		"schema-dts": "^1.1.5",
		"tailwindcss": "^4.3.2",
		"typescript": "^5.9.3"
